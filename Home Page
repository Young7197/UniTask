<!DOCTYPE html>
<html>
<head>
    <title>Task Manager Prototype</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>
    <h1>Task Manager</h1>

    <h2>Add a Task</h2>
    <a href="/add">
        <button>Add Task</button>
    </a>


    <h2>All Tasks</h2>
    <ul id="taskList">
        {% for task in tasks %}
            <li>{{ task['name'] }}</li>
        {% endfor %}
    </ul>

    <h2>Suggestions</h2>
    <input type="text" id="suggestInput" placeholder="Type keyword...">
    <ul id="suggestionsList"></ul>

    <script src="{{ url_for('static', filename='script.js') }}"></script>
</body>
</html>
