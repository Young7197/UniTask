/*Style format for html bodies*/
body {
    font-family: Arial, sans-serif;
    margin: 20px;
}

/*Style format for html buttons*/
input, button {
    padding: 5px;
    margin: 5px 0;
}

/*Style format for html uls*/
ul {
    list-style-type: none;
    padding-left: 0;
}

/*Color for high-priority tasks*/
.priority-High {
    color: red;
}

/*Color for medium-priority tasks*/
.priority-Medium {
    color: orange;
}

/*Color for low-priority tasks*/
.priority-Low {
    color: green;
}
