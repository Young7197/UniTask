from flask import Flask, request, jsonify, render_template, redirect, url_for
from datetime import datetime

app = Flask(__name__)

#Store user tasks & suggestions
tasks = []
suggestions = []

#API call for the home page
@app.route('/home')
def home():
    #Returns the home page's HTML with the tasks in order by due date
    sorted_tasks = sorted(tasks, key=lambda task: task['dueDate'])
    return render_template('index.html', tasks=sorted_tasks, suggestions=suggestions)

#API call for adding and viewing a task
@app.route('/add', methods=['GET', 'POST'])
def add_task_page():
    #Parameters requested when adding a task
    if request.method == 'POST':
        task_name = request.form.get('task_name')
        task_desc = request.form.get('task_desc')
        task_class = request.form.get('task_class')
        task_date_str = request.form.get('task_date')
        task_date = datetime.strptime(task_date_str, "%Y-%m-%d")
        task_priority = request.form.get('task_priority')

        #If a task is created, these are its parameters
        if task_name:
            task = {
                'id': len(tasks) + 1, #autogenerated
                'name': task_name, #required
                'description': task_desc, #not required
                'class': task_class, #not required
                'dueDate': task_date, #required
                'priority': task_priority #not required
            }
            
            #Add task & (possibly) generate suggestion
            tasks.append(task)
            generate_suggestion(task_name, task_date)

        #When finished, redirected back to the home screen
        return redirect(url_for('home'))
    return render_template('add_task.html')

#API call for getting the tasks
@app.route('/tasks', methods=['GET'])
#Getting the tasks and their information
def get_tasks():
    return jsonify({'tasks': tasks})

#Generating suggestions
def generate_suggestion(task_name, task_date):
    task_lowercase = task_name.lower()
    
    #Generate study suggestions based on test keywords
    if "test" in task_lowercase or "exam" in task_lowercase or "quiz" in task_lowercase:
        suggestion_text = f"Study for {task_name}"
        suggestions.append(suggestion_text)
    
    #Generate breakdown suggestions based on assignment keywords
    elif "essay" in task_lowercase or "project" in task_lowercase:
        suggestion_text = f"Break down {task_name} into multiple work sessions"
        suggestions.append(suggestion_text)

    #Time-based suggestions
    for task in tasks:
        days_remaining = (task_date.date() - datetime.now().date()).days
        
        #Assignments due tomorrow
        if days_remaining == 1:
            suggestion_text = f"{task_name} is due Tomorrow!"
            suggestions.append(suggestion_text)
            break

        #Assignments due today
        elif days_remaining == 0:
            suggestion_text = f"With {task_name} is due Today!"
            suggestions.append(suggestion_text)
            break

        #Overdue assignments
        elif days_remaining < 0:
            suggestion_text = f"{task_name} is overdue!"
            suggestions.append(suggestion_text)
            break

if __name__ == '__main__':
    app.run(debug=True)
